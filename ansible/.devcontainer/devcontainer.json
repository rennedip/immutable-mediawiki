{
	"name": "Debian",
	"build": {
		"dockerfile": "Dockerfile"
	},


	"remoteUser": "root",
	"postCreateCommand": "chmod -R o-w /workspaces/${localWorkspaceFolderBasename} && chmod -R u+rwX,go= /root/.ssh && chmod -R u+rwX,go= /root/.keys && chmod -R u+rwX,go= /root/.secrets",
	"mounts": [
		"source=c/Users/me/.ssh,target=/root/.ssh,type=bind,consistency=cached",
		"source=c/Users/me/.secrets,target=/root/.secrets,type=bind,consistency=cached",
		"source=c/Users/me/.keys,target=/root/.keys,type=bind,consistency=cached"
	],
	"containerEnv": {
		"INFISICAL_UNIVERSAL_AUTH_CLIENT_ID": "${localEnv:INFISICAL_UNIVERSAL_AUTH_CLIENT_ID}",
		"INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET": "${localEnv:INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"redhat.ansible"
			]
		}
	}
}